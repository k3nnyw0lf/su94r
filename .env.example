# ═══════════════════════════════════════════════════════
# su94r — Environment Variables
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to GitHub.
# ALL keys are optional — app works without any.
# ═══════════════════════════════════════════════════════

# ── FREE AI Models (add at least one) ──────────────────
# Groq — fastest free LLMs · console.groq.com
VITE_GROQ_API_KEY=

# Google Gemini Flash — free · aistudio.google.com
VITE_GEMINI_API_KEY=

# Mistral — free tier · console.mistral.ai
VITE_MISTRAL_API_KEY=

# Hugging Face — free · huggingface.co/settings/tokens
VITE_HF_API_KEY=

# Ollama — local, totally free & private · ollama.ai
VITE_OLLAMA_ENDPOINT=http://localhost:11434
VITE_OLLAMA_MODEL=llama3

# ── Paid AI (optional — best medical reasoning) ────────
VITE_CLAUDE_API_KEY=
VITE_OPENAI_API_KEY=

# ── Nutrition APIs (free) ──────────────────────────────
# USDA FoodData · fdc.nal.usda.gov/api-guide.html
VITE_USDA_API_KEY=DEMO_KEY

# Nutritionix (500 free/day) · developer.nutritionix.com
VITE_NUTRITIONIX_APP_ID=
VITE_NUTRITIONIX_API_KEY=

# ── Push Notifications ─────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# ── Optional: Supabase (sync across devices) ───────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
